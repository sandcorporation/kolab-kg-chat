{"openapi": "3.1.0", "info": {"title": "Kolab KG Chat API", "version": "0.1.0", "description": ""}, "paths": {"/health": {"get": {"operationId": "apps_core_api_health", "summary": "Health", "parameters": [], "responses": {"200": {"description": "OK"}}, "description": "리브니스 + DB(age·vector 확장) 가용성 체크 (이슈 02)."}}, "/recommend": {"post": {"operationId": "apps_agent_api_recommend_endpoint", "summary": "Recommend Endpoint", "parameters": [], "responses": {"200": {"description": "OK"}}, "requestBody": {"content": {"application/json": {"schema": {"$ref": "#/components/schemas/RecommendIn"}}}, "required": true}}}, "/chat/schema": {"post": {"operationId": "apps_agent_api_chat_event_schema", "summary": "Chat Event Schema", "parameters": [], "responses": {"200": {"description": "OK", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/ChatEventCatalog"}}}}}, "description": "코드젠 전용: POST /chat 요청 본문(ChatIn)과 SSE 이벤트 페이로드 타입을 노출한다.\n\n실제 대화는 스트리밍 뷰 POST /chat이 처리한다(SSE, text/event-stream).", "requestBody": {"content": {"application/json": {"schema": {"$ref": "#/components/schemas/ChatIn"}}}, "required": true}}}}, "components": {"schemas": {"RecommendIn": {"properties": {"query": {"title": "Query", "type": "string"}}, "required": ["query"], "title": "RecommendIn", "type": "object"}, "ChatEventCatalog": {"description": "SSE 이벤트 페이로드 카탈로그(코드젠 전용).", "properties": {"token": {"$ref": "#/components/schemas/TokenData"}, "recommendation": {"$ref": "#/components/schemas/RecommendationData"}, "clarification": {"$ref": "#/components/schemas/ClarificationData"}, "error": {"$ref": "#/components/schemas/ErrorData"}}, "required": ["token", "recommendation", "clarification", "error"], "title": "ChatEventCatalog", "type": "object"}, "ClarificationData": {"description": "event: clarification — 되묻기 문구.", "properties": {"question": {"title": "Question", "type": "string"}}, "required": ["question"], "title": "ClarificationData", "type": "object"}, "ErrorData": {"description": "event: error — 스트림 내 오류.", "properties": {"message": {"title": "Message", "type": "string"}}, "required": ["message"], "title": "ErrorData", "type": "object"}, "GroundingItem": {"properties": {"name": {"title": "Name", "type": "string"}, "value": {"title": "Value", "type": "string"}, "provenance": {"title": "Provenance", "type": "string"}}, "required": ["name", "value", "provenance"], "title": "GroundingItem", "type": "object"}, "ProductCard": {"properties": {"source_id": {"title": "Source Id", "type": "string"}, "name": {"title": "Name", "type": "string"}, "url": {"title": "Url", "type": "string"}, "image_url": {"anyOf": [{"type": "string"}, {"type": "null"}], "title": "Image Url"}, "grounding": {"default": [], "items": {"$ref": "#/components/schemas/GroundingItem"}, "title": "Grounding", "type": "array"}}, "required": ["source_id", "name", "url"], "title": "ProductCard", "type": "object"}, "RecommendationData": {"description": "event: recommendation — 결정적으로 부착된 상품 카드.", "properties": {"products": {"default": [], "items": {"$ref": "#/components/schemas/ProductCard"}, "title": "Products", "type": "array"}}, "title": "RecommendationData", "type": "object"}, "TokenData": {"description": "event: token — 추천 근거 토큰 조각.", "properties": {"content": {"title": "Content", "type": "string"}}, "required": ["content"], "title": "TokenData", "type": "object"}, "ChatIn": {"description": "POST /chat 요청 본문.", "properties": {"query": {"title": "Query", "type": "string"}}, "required": ["query"], "title": "ChatIn", "type": "object"}}}, "servers": []}
