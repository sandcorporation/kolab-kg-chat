{"openapi": "3.1.0", "info": {"title": "Kolab KG Chat API", "version": "0.1.0", "description": ""}, "paths": {"/health": {"get": {"operationId": "apps_core_api_health", "summary": "Health", "parameters": [], "responses": {"200": {"description": "OK"}}, "description": "\ub9ac\ube0c\ub2c8\uc2a4 + DB(vector\u00b7pg_trgm \ud655\uc7a5) \uac00\uc6a9\uc131 \uccb4\ud06c."}}, "/chat/schema": {"post": {"operationId": "apps_agent_api_chat_event_schema", "summary": "Chat Event Schema", "parameters": [], "responses": {"200": {"description": "OK", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/ChatEventCatalog"}}}}}, "description": "\ucf54\ub4dc\uc820 \uc804\uc6a9: POST /chat \uc694\uccad \ubcf8\ubb38(ChatIn)\uacfc SSE \uc774\ubca4\ud2b8 \ud398\uc774\ub85c\ub4dc \ud0c0\uc785\uc744 \ub178\ucd9c\ud55c\ub2e4.", "requestBody": {"content": {"application/json": {"schema": {"$ref": "#/components/schemas/ChatIn"}}}, "required": true}}}}, "components": {"schemas": {"ChatEventCatalog": {"description": "SSE \uc774\ubca4\ud2b8 \ud398\uc774\ub85c\ub4dc \uce74\ud0c8\ub85c\uadf8(\ucf54\ub4dc\uc820 \uc804\uc6a9).", "properties": {"token": {"$ref": "#/components/schemas/TokenData"}, "recommendation": {"$ref": "#/components/schemas/RecommendationData"}, "clarification": {"$ref": "#/components/schemas/ClarificationData"}, "status": {"$ref": "#/components/schemas/StatusData"}, "error": {"$ref": "#/components/schemas/ErrorData"}, "suggestions": {"$ref": "#/components/schemas/SuggestionsData"}, "notice": {"$ref": "#/components/schemas/NoticeData"}}, "required": ["token", "recommendation", "clarification", "status", "error", "suggestions", "notice"], "title": "ChatEventCatalog", "type": "object"}, "ClarificationData": {"description": "event: clarification \u2014 \ub418\ubb3b\uae30 \ubb38\uad6c.", "properties": {"question": {"title": "Question", "type": "string"}}, "required": ["question"], "title": "ClarificationData", "type": "object"}, "ErrorData": {"description": "event: error \u2014 \uc2a4\ud2b8\ub9bc \ub0b4 \uc624\ub958.", "properties": {"message": {"title": "Message", "type": "string"}}, "required": ["message"], "title": "ErrorData", "type": "object"}, "GroundingItem": {"properties": {"name": {"title": "Name", "type": "string"}, "value": {"title": "Value", "type": "string"}, "provenance": {"title": "Provenance", "type": "string"}}, "required": ["name", "value", "provenance"], "title": "GroundingItem", "type": "object"}, "NoticeData": {"description": "event: notice \u2014 \ud488\uc808 \uc0c1\ud488 \uad6c\ub9e4\uc694\uccad \uc548\ub0b4(\ud504\ub86c\ud504\ud2b8 + \uc0c1\ud488\ubcc4 \uc694\uccad \ubc84\ud2bc).", "properties": {"prompt": {"default": "", "title": "Prompt", "type": "string"}, "items": {"default": [], "items": {"type": "string"}, "title": "Items", "type": "array"}}, "title": "NoticeData", "type": "object"}, "ProductCard": {"properties": {"source_id": {"title": "Source Id", "type": "string"}, "name": {"title": "Name", "type": "string"}, "url": {"title": "Url", "type": "string"}, "image_url": {"anyOf": [{"type": "string"}, {"type": "null"}], "title": "Image Url"}, "price_min": {"anyOf": [{"type": "integer"}, {"type": "null"}], "title": "Price Min"}, "price_max": {"anyOf": [{"type": "integer"}, {"type": "null"}], "title": "Price Max"}, "soldout": {"default": false, "title": "Soldout", "type": "boolean"}, "soldout_options": {"default": [], "items": {"type": "string"}, "title": "Soldout Options", "type": "array"}, "grounding": {"default": [], "items": {"$ref": "#/components/schemas/GroundingItem"}, "title": "Grounding", "type": "array"}}, "required": ["source_id", "name", "url"], "title": "ProductCard", "type": "object"}, "RecommendationData": {"description": "event: recommendation \u2014 \uacb0\uc815\uc801\uc73c\ub85c \ubd80\ucc29\ub41c \uc0c1\ud488 \uce74\ub4dc.", "properties": {"products": {"default": [], "items": {"$ref": "#/components/schemas/ProductCard"}, "title": "Products", "type": "array"}}, "title": "RecommendationData", "type": "object"}, "StatusData": {"description": "event: status \u2014 \ub3c4\uad6c \ud638\ucd9c \uc9c4\ud589 \uc0c1\ud0dc(\uccab \ud1a0\ud070 \uc804 \uc804\ud658\ud615 \ud45c\uc2dc).", "properties": {"label": {"title": "Label", "type": "string"}}, "required": ["label"], "title": "StatusData", "type": "object"}, "SuggestionsData": {"description": "event: suggestions \u2014 \uc751\ub2f5 \ub4a4 \ud6c4\uc18d \uac80\uc0c9\uc5b4 \uce69(\ud074\ub9ad\ud574 \ub300\ud654 \uc9c0\uc18d).", "properties": {"suggestions": {"default": [], "items": {"type": "string"}, "title": "Suggestions", "type": "array"}}, "title": "SuggestionsData", "type": "object"}, "TokenData": {"description": "event: token \u2014 \ucd94\ucc9c \uadfc\uac70 \ud1a0\ud070 \uc870\uac01.", "properties": {"content": {"title": "Content", "type": "string"}}, "required": ["content"], "title": "TokenData", "type": "object"}, "ChatIn": {"description": "POST /chat \uc694\uccad \ubcf8\ubb38.", "properties": {"query": {"title": "Query", "type": "string"}, "history": {"default": [], "items": {"$ref": "#/components/schemas/HistoryMessage"}, "title": "History", "type": "array"}}, "required": ["query"], "title": "ChatIn", "type": "object"}, "HistoryMessage": {"description": "\ubb34\uc0c1\ud0dc \uba40\ud2f0\ud134 \ud788\uc2a4\ud1a0\ub9ac \ud55c \uc904. role: user | assistant.", "properties": {"role": {"title": "Role", "type": "string"}, "content": {"title": "Content", "type": "string"}}, "required": ["role", "content"], "title": "HistoryMessage", "type": "object"}}}, "servers": []}