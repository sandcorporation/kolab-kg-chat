{"openapi": "3.1.0", "info": {"title": "Kolab KG Chat API", "version": "0.1.0", "description": ""}, "paths": {"/health": {"get": {"operationId": "apps_core_api_health", "summary": "Health", "parameters": [], "responses": {"200": {"description": "OK"}}, "description": "\ub9ac\ube0c\ub2c8\uc2a4 + DB(age\u00b7vector \ud655\uc7a5) \uac00\uc6a9\uc131 \uccb4\ud06c (\uc774\uc288 02)."}}, "/chat/schema": {"post": {"operationId": "apps_agent_api_chat_event_schema", "summary": "Chat Event Schema", "parameters": [], "responses": {"200": {"description": "OK", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/ChatEventCatalog"}}}}}, "description": "\ucf54\ub4dc\uc820 \uc804\uc6a9: POST /chat \uc694\uccad \ubcf8\ubb38(ChatIn)\uacfc SSE \uc774\ubca4\ud2b8 \ud398\uc774\ub85c\ub4dc \ud0c0\uc785\uc744 \ub178\ucd9c\ud55c\ub2e4.", "requestBody": {"content": {"application/json": {"schema": {"$ref": "#/components/schemas/ChatIn"}}}, "required": true}}}}, "components": {"schemas": {"ChatEventCatalog": {"description": "SSE \uc774\ubca4\ud2b8 \ud398\uc774\ub85c\ub4dc \uce74\ud0c8\ub85c\uadf8(\ucf54\ub4dc\uc820 \uc804\uc6a9).", "properties": {"token": {"$ref": "#/components/schemas/TokenData"}, "recommendation": {"$ref": "#/components/schemas/RecommendationData"}, "clarification": {"$ref": "#/components/schemas/ClarificationData"}, "status": {"$ref": "#/components/schemas/StatusData"}, "error": {"$ref": "#/components/schemas/ErrorData"}}, "required": ["token", "recommendation", "clarification", "status", "error"], "title": "ChatEventCatalog", "type": "object"}, "ClarificationData": {"description": "event: clarification \u2014 \ub418\ubb3b\uae30 \ubb38\uad6c.", "properties": {"question": {"title": "Question", "type": "string"}}, "required": ["question"], "title": "ClarificationData", "type": "object"}, "ErrorData": {"description": "event: error \u2014 \uc2a4\ud2b8\ub9bc \ub0b4 \uc624\ub958.", "properties": {"message": {"title": "Message", "type": "string"}}, "required"