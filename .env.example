# Kolab KG Chat — 환경 변수 (복사해서 .env 로 채우세요)

# ── OpenAI (추천 에이전트 / 속성 추출) ── [필수]
OPEN_AI_KEY=sk-your-key-here
OPENAI_MODEL=gpt-4o-mini            # (선택) 추천 에이전트·속성 추출 모델
#EMBEDDING_MODEL=text-embedding-3-small  # (선택) semantic_search 임베딩 모델(ADR-0012). 저렴.

# ── 추천 읽기 경로: RAG · 메모리 · 컨텍스트 방어 (ADR-0015/0014/0013) ── [선택]
#RAG_TOP_K=20              # 검색 후보 수(키워드∪시맨틱 top-K). 클수록 리콜↑·프롬프트↑.
#RAG_DESCRIPTION_MODEL=gpt-4o-mini  # 적재 시 상품 임베딩 강화용 설명 생성 모델(ADR-0015). 기본 OPENAI_MODEL.
#AGENT_MAX_ITERS=3         # 반복 검색 최대 횟수(ADR-0017). 불만족 시 재검색어로 재시도. 1이면 사실상 단일 패스. 클수록 품질↑·LLM 콜↑(채팅당 2~6).
# 숫자 하드 필터(ADR-0018): "3000만원 이하"·"순도 99% 이상"·"냉장 2~8도" 같은 숫자 제약은 적재 시
# kg_embedding에 색인한 숫자 컬럼(가격·순도·분자량·보관온도)으로 필터한다. 별도 플래그 없음(제약이
# 있는 질의에만 적용). 신규 컬럼은 기존 행에 NULL이라 도입 시 재적재 필요: embed_products --reset.
# 브랜드·재질 등 범주형은 임베딩이 처리(하드 필터 아님).
#AGENT_TOKEN_BUDGET=6000   # 모델 호출 직전 메시지 토큰 예산(초과 시 오래된 것부터 트림, 시스템 유지).
#AGENT_HISTORY_TURNS=5     # 클라이언트 히스토리에서 반영할 최근 대화 턴 수 상한(무상태 멀티턴).

# ── 소스 DB (상품 원본, 예: 영카트/그누보드 MariaDB) ──
# dev/test: 설정 불필요 — override의 번들 mock source-db를 자동 사용.
# prod/납품: 아래에 고객사 실 DB 접속정보를 채운다(이 값이 실제로 사용됨). 읽기 전용 계정 권장.
# 중요(C, ADR-0016): 적재와 채팅이 같은 소스를 가리켜야 한다 — 채팅 때 상품 사실을 소스에서
# 하이드레이션하므로, 적재한 소스와 다른 DB를 보면 추천 카드가 비어 나온다.
#SOURCE_DB_HOST=your-db-host
#SOURCE_DB_PORT=3306
#SOURCE_DB_USER=readonly_user
#SOURCE_DB_PASSWORD=change-me
#SOURCE_DB_NAME=your_shop_db

# ── 우리 검색 색인 DB (Postgres + pgvector + pg_trgm) ── [함께 배포됨]
# 임베딩·설명만 보관한다(상품 사실은 소스에서 하이드레이션, ADR-0016). Apache AGE 없음.
# 비밀번호 변경 시 POSTGRES_PASSWORD 지정(기본 kolab). DATABASE_URL은 compose가 구성한다.
#POSTGRES_PASSWORD=kolab

# ── 적재(ingest_products) 튜닝 ── [선택, 저사양 박스에서 조절]
#INGEST_BATCH_SIZE=500     # 배치 크기(커밋 주기). 작을수록 메모리·트랜잭션 작고, 클수록 빠름.
#INGEST_PAGE_SIZE=1000     # 소스 id 키셋 페이지 크기(한 번에 가져오는 id 수).
#INGEST_LLM=0              # 1이면 적재 시 설명 텍스트에서 Functional Attribute까지 LLM 추출(비용).

# ── 동기화 워커(sync_poll) 튜닝 ── [선택, prod worker가 .env로 제어됨]
#SYNC_INTERVAL=3600        # 폴링 주기(초).
#SYNC_RECONCILE_EVERY=24   # N 사이클마다 전체 재조정(삭제·드리프트 보정). 0=하지 않음.
#SYNC_LLM=0                # 1이면 변경분을 LLM으로 재추출(비용).

# ── PDF 문서 강화(적재 시 설명 풍부화) ── [선택, 세 적재 경로 모두 적용]
# 상품 행의 직접-PDF URL을 읽어 스펙시트/매뉴얼 텍스트를 LLM 설명 생성에 넣는다(검색 리콜↑,
# 채팅 비용·지연 불변). content-hash로 게이팅(안 바뀐 상품 재fetch 없음). PDF 교체를 반영하려면
# 교체 시 URL에 버전을 넣어라(예: spec_v2.pdf 또는 ?v=YYYYMMDD) — URL 변경이 자동 재처리를 유발.
#INGEST_PDF=0              # 1이면 적재 시 PDF 패스를 읽어 설명 강화(비용↑). 기본 꺼짐.
#PDF_FIELD=it_pdf_url      # 직접-PDF URL을 담은 소스 컬럼명(고객사가 컬럼 이름만 맞추면 됨).
#PDF_MAX_CHARS=6000        # LLM 설명 프롬프트에 넣을 PDF 텍스트 상한(입력 토큰·비용 제어).
#PDF_MAX_BYTES=10485760    # PDF fetch 크기 상한(10MB). 스트리밍 중 초과 시 스킵.
#PDF_HTTP_TIMEOUT=10       # PDF fetch 타임아웃(초).

# (dev 전용) AGENT_FAKE=1 이면 OpenAI 없이 결정적 데모/E2E. 보통 셸에서 지정한다.
