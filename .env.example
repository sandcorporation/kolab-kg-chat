# Kolab KG Chat — 환경 변수 (복사해서 .env 로 채우세요)

# ── OpenAI (추천 에이전트 / 속성 추출) ── [필수]
OPEN_AI_KEY=sk-your-key-here
OPENAI_MODEL=gpt-4o-mini            # (선택) 추천 에이전트·속성 추출 모델
#OPENAI_VISION_MODEL=gpt-4o         # (선택) 이미지에서 스펙 추출 시(--llm 비전 경로)
#EMBEDDING_MODEL=text-embedding-3-small  # (선택) semantic_search 임베딩 모델(ADR-0012). 저렴.

# ── 소스 DB (상품 원본, 예: 영카트/그누보드 MariaDB) ──
# dev/test: 설정 불필요 — override의 번들 mock source-db를 자동 사용.
# prod/납품: 아래에 고객사 실 DB 접속정보를 채운다(이 값이 실제로 사용됨). 읽기 전용 계정 권장.
#SOURCE_DB_HOST=your-db-host
#SOURCE_DB_PORT=3306
#SOURCE_DB_USER=readonly_user
#SOURCE_DB_PASSWORD=change-me
#SOURCE_DB_NAME=your_shop_db

# ── 우리 Knowledge Graph DB (Postgres + Apache AGE) ── [함께 배포됨]
# 비밀번호 변경 시 POSTGRES_PASSWORD 지정(기본 kolab). DATABASE_URL은 compose가 구성한다.
#POSTGRES_PASSWORD=kolab

# ── 적재(ingest_products) 튜닝 ── [선택, 저사양 박스에서 조절]
#INGEST_BATCH_SIZE=500     # 배치 크기(커밋 주기). 작을수록 메모리·트랜잭션 작고, 클수록 빠름.
#INGEST_PAGE_SIZE=1000     # 소스 id 키셋 페이지 크기(한 번에 가져오는 id 수).
#INGEST_LLM=0              # 1이면 적재 시 설명 텍스트에서 Functional Attribute까지 LLM 추출(비용).

# ── 동기화 워커(sync_poll) 튜닝 ── [선택, prod worker가 .env로 제어됨]
#SYNC_INTERVAL=3600        # 폴링 주기(초).
#SYNC_RECONCILE_EVERY=24   # N 사이클마다 전체 재조정(삭제·드리프트 보정). 0=하지 않음.
#SYNC_LLM=0                # 1이면 변경분을 LLM으로 재추출(비용).

# (dev 전용) AGENT_FAKE=1 이면 OpenAI 없이 결정적 데모/E2E. 보통 셸에서 지정한다.
